<?xml version="1.0" encoding="UTF-8" ?>

<objectives>
  <ul>
    <li>
      <p>
        Determine the equation of a tangent line.
      </p>
    </li>
    <li>
      <p>
        Use the tangent line to approximate the value of the function
        at nearby points.
      </p>
    </li>
    <li>
      <p>
        Use information about the second derivative to assess the
        accuracy of the approximation.
      </p>
    </li>
  </ul>
</objectives>

