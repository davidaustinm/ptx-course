<worksheet xml:id="worksheet-tangent"
           xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Tangent line approximations</title>

  <p><alert>MTH 201: January 20</alert></p>

  <xi:include href="include/tangent-objectives.ptx"/>

